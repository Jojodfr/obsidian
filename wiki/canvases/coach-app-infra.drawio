        <mxCell id="cf-dist" value="&lt;b&gt;CloudFront Distribution&lt;/b&gt;&lt;br&gt;&lt;br&gt;• HSTS (2 years + preload)&lt;br&gt;• X-Frame-Options DENY&lt;br&gt;• Strict CSP (GA, Fonts, S3)&lt;br&gt;• Referrer strict-origin&lt;br&gt;• TLS 1.2_2021&lt;br&gt;&lt;br&gt;5 Cache Behaviors:" style="rounded=1;arcSize=4;fillColor=#262626;strokeColor=#16a34a;strokeWidth=2;fontColor=#FFFFFF;fontSize=11;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="380" y="140" width="280" height="140" as="geometry" />
        </mxCell>

